PORT=4000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CLIENT_URL=http://localhost:5173

# Email Configuration (optional)
# Leave empty to use Ethereal test account (emails preview in console/browser)
# For production, configure real SMTP provider

# Gmail (requires App Password with 2FA enabled)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
# EMAIL_FROM="FragForge" <your-email@gmail.com>

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxx
# SMTP_SECURE=false
# EMAIL_FROM="FragForge" <noreply@fragforge.dev>

# Initial admin account (created on first start)
ADMIN_EMAIL=admin@fragforge.dev
ADMIN_PASSWORD=change-me-on-first-login
ADMIN_USERNAME=admin
